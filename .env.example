# SOC Triage AI — Environment Variable Template
#
# Analogy: this file is a "blank form" you can photocopy—it's safe to share,
# and you fill the real answers into your private `.env` (which must never be committed).
#
# IMPORTANT:
# - Do NOT put real secrets in this file.
# - Create a local `.env` and copy values there.

########################################
# OpenAI (LLM)
########################################
# OpenAI API key used by `app/llm_client.py`
OPENAI_API_KEY="REPLACE_ME"
# Model name (example only; adjust as needed)
OPENAI_MODEL="gpt-4o"
# Seconds before we fallback to rule-based triage
OPENAI_TIMEOUT_SECONDS="20"

########################################
# VirusTotal (IP / hash reputation)
########################################
VIRUSTOTAL_API_KEY="REPLACE_ME"
VIRUSTOTAL_TIMEOUT_SECONDS="10"

########################################
# AbuseIPDB (IP reputation)
########################################
ABUSEIPDB_API_KEY="REPLACE_ME"
ABUSEIPDB_TIMEOUT_SECONDS="10"

########################################
# Splunk (REST API + HEC)
########################################
SPLUNK_BASE_URL="https://splunk.example.local:8089"
SPLUNK_USERNAME="REPLACE_ME"
SPLUNK_PASSWORD="REPLACE_ME"
SPLUNK_HEC_URL="https://splunk.example.local:8088"
SPLUNK_HEC_TOKEN="REPLACE_ME"
SPLUNK_VERIFY_TLS="true"
SPLUNK_TIMEOUT_SECONDS="15"

########################################
# PostgreSQL (SQLAlchemy)
########################################
# Example only; use your real local Postgres connection string in `.env`
DATABASE_URL="postgresql+psycopg://REPLACE_ME:REPLACE_ME@localhost:5432/soc_triage_ai"

########################################
# AWS (Lambda/ECR/SSM/CloudWatch)
########################################
# In production, prefer IAM roles + SSM Parameter Store; these are placeholders for local dev.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="REPLACE_ME"
AWS_SECRET_ACCESS_KEY="REPLACE_ME"
AWS_SESSION_TOKEN="REPLACE_ME"

########################################
# App settings
########################################
APP_ENV="local"
LOG_LEVEL="INFO"
# Used for any redaction/sanitization salt or request IDs if needed later (placeholder only)
APP_INSTANCE_ID="local-dev"

